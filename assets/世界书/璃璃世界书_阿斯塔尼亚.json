    {
      "id": "worldbook-magic-system",
      "title": "属性魔法体系",
      "trigger": "属性魔法,魔法咏唱,魔法体系,火属性,水属性,风属性,土属性,光属性,暗属性",
      "secondary_trigger": "",
      "entry_type": "keyword",
      "group_operator": "and",
      "match_mode": "any",
      "secondary_mode": "all",
      "content": "【即时属性魔法】由施法者血统与天赋决定，通常需要通过语言咏唱来引导魔力，咏唱音节越复杂、时间越长，调动元素越多，威力越强。基础属性为火（破坏/爆裂）、水（控制/绝对冻结）、风（速度/真空刃）、土（防御/地动）。稀有属性为光（治愈/净化，教会吸纳）、暗（侵蚀/诅咒，被视为异端）。无咏唱且不削弱威力是转生者琳妮娅独创的「世界级Bug」。",
      "group": "世界观设定",
      "chance": 100,
      "sticky_turns": 0,
      "cooldown_turns": 0,
      "order": 100,
      "priority": 100,
      "enabled": true,
      "case_sensitive": false,
      "whole_word": false,
      "comment": "核心魔法体系"
    },
    {
      "id": "worldbook-rune-magic",
      "title": "符文魔法体系",
      "trigger": "符文魔法,魔法阵,仪式魔法,符文,魔阵",
      "secondary_trigger": "",
      "entry_type": "keyword",
      "group_operator": "and",
      "match_mode": "any",
      "secondary_mode": "all",
      "content": "【符文魔法（阵地与仪式体系）】独立于血统属性魔法之外，需要在纸张、地面或特定材质上刻画复杂的魔法阵/符文来启动。不需要口头咏唱，但需要庞大的魔力源（施法者透支或大量魔石/精灵石）以及特定的物质介质（极其稀有的魔兽素材、特殊的导魔矿物）。常用于：大型城市防御结界、跨空间召唤术、永久性魔牢等。",
      "group": "世界观设定",
      "chance": 100,
      "sticky_turns": 0,
      "cooldown_turns": 0,
      "order": 100,
      "priority": 100,
      "enabled": true,
      "case_sensitive": false,
      "whole_word": false,
      "comment": "符文魔法"
    },
